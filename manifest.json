{
  "manifest_version": 3,
  "name": "Busca Midias TMDB",
  "version": "1.0.0",
  "description": "Detecta links magnet na página, limpa nomes, busca metadados no TMDB e exibe no popup.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://api.themoviedb.org/*",
    "https://image.tmdb.org/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Busca Torrent TMDB"
  }
}
